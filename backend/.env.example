GCP_PROJECT_ID=tomorrow-planter
# Vertex AI Gemini / Embeddings region.
# gemini-3.5-flash は us-central1 非対応。asia-northeast1 または global を使う。
GCP_LOCATION=asia-northeast1
FIREBASE_PROJECT_ID=tomorrow-planter
GEMINI_MODEL=gemini-3.5-flash
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
CORS_ORIGINS=*
# Local UI-only smoke tests. Keep false when using Firebase Auth tokens.
AUTH_DISABLED=false
# GOOGLE_APPLICATION_CREDENTIALS=../secrets/backend-sa.json
